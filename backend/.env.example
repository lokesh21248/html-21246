# ==============================
# Server
# ==============================
PORT=3001
NODE_ENV=production

# ==============================
# Supabase Credentials
# ==============================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================
# CORS — Allowed Frontend Origins
# ==============================
# Comma-separated. Must include your Vercel deployment URL.
ALLOWED_ORIGINS=https://html-21246.vercel.app,http://localhost:3000,http://localhost:3001

# ==============================
# Note: JWT_SECRET is NOT used.
# Auth is handled via Supabase JWT (supabasePublic.auth.getUser())
# ==============================
